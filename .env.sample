# --- Microsoft 365 Agents SDK (Bot Framework) credentials ---
# From your Azure Bot registration / App Registration.
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<bot-app-client-id>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=<bot-app-client-secret>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<tenant-id>

# --- Microsoft Foundry project ---
# Example: https://<project-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=
# Name of a chat model deployment inside your Foundry project (e.g. gpt-4.1-mini)
FOUNDRY_MODEL_DEPLOYMENT=gpt-4.1-mini

# --- Server ---
PORT=3978
HOST=0.0.0.0
LOG_LEVEL=INFO

# --- Telemetry (optional locally; set by Bicep in Azure) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
