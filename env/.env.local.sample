# Committed env values for `local` (F5 → real Teams via dev tunnel).
# Secrets live in env/.env.local.user (gitignored).
# The Toolkit fills these in per-developer at provision time — do NOT commit your filled values.

TEAMSFX_ENV=local
APP_NAME_SUFFIX=local

# Filled by the Toolkit during provision:
TEAMS_APP_ID=
BOT_ID=
BOT_OBJECT_ID=
BOT_TENANT_ID=
BOT_ENDPOINT=
BOT_DOMAIN=
TEAMS_APP_TENANT_ID=