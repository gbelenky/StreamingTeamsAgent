{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "botAppId": {
      "value": "${BOT_APP_ID}"
    },
    "botAppSecret": {
      "value": "${BOT_APP_SECRET}"
    },
    "botTenantId": {
      "value": "${BOT_TENANT_ID=${AZURE_TENANT_ID}}"
    },
    "foundryProjectEndpoint": {
      "value": "${FOUNDRY_PROJECT_ENDPOINT}"
    },
    "foundryModelDeployment": {
      "value": "${FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-mini}"
    },
    "foundryAccountResourceId": {
      "value": "${FOUNDRY_ACCOUNT_RESOURCE_ID=}"
    }
  }
}
